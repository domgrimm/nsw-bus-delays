# TfNSW API
TFNSW_API_KEY=<replace_me>

# PostgreSQL
DATABASE_URL=postgresql://nswbus:nswbus@db:5432/nswbusdelays
POSTGRES_USER=nswbus
POSTGRES_PASSWORD=nswbus
POSTGRES_DB=nswbusdelays

# Polling
POLLING_INTERVAL_SECONDS=60

# Thresholds
ON_TIME_THRESHOLD_SECONDS=120
MAX_CONSECUTIVE_FAILURES=5

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3000
